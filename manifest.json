{
  "manifest_version": 3,
  "name": "CaseSync",
  "version": "1.1.0",
  "description": "Stay on top of every customer call",
  "author": "Niteesh L, Your next desk intern",
  "icons": {
    "16": "logo.png",
    "32": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  },
  "permissions": ["tabs", "storage"],
  "host_permissions": [
    "*://support.servicenow.com/*",
    "*://outlook.office.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://support.servicenow.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
