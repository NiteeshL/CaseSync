{
  "manifest_version": 3,
  "name": "ServiceNow ICS to Outlook",
  "version": "1.0.0",
  "description": "Detects .ics invites in ServiceNow Work Notes and opens a pre-filled Outlook Web event.",
  "permissions": ["tabs"],
  "host_permissions": [
    "*://*.service-now.com/*",
    "*://outlook.office.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.service-now.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
