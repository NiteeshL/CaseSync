{
  "manifest_version": 3,
  "name": "ServiceNow ICS to Outlook",
  "version": "1.1.0",
  "description": "Detects meeting scheduling requests in ServiceNow and opens a pre-filled Outlook Web event.",
  "permissions": ["tabs", "storage"],
  "host_permissions": [
    "<all_urls>",
    "*://outlook.office.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
